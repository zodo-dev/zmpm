{
  "name": "@zodo/zmpm",
  "version": "0.1.0",
  "description": "Zodo Meteor Package Manager — vendor Meteor packages into an app's packages/ dir from GitHub Releases or any tarball URL, with auth and transitive-dependency resolution. A generic alternative to Atmosphere for private/self-hosted packages.",
  "type": "module",
  "bin": {
    "zmpm": "bin/zmpm.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node test/run.mjs"
  },
  "files": [
    "bin",
    "src",
    "examples",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "tar": "^7.4.3"
  },
  "keywords": [
    "meteor",
    "meteorjs",
    "meteor-packages",
    "package-manager",
    "cli",
    "atmosphere",
    "atmosphere-alternative",
    "github-releases",
    "vendoring",
    "vendor",
    "private-packages",
    "npm",
    "nodejs",
    "devtools"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/zodo-dev/zmpm#readme",
  "bugs": {
    "url": "https://github.com/zodo-dev/zmpm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zodo-dev/zmpm.git"
  }
}
